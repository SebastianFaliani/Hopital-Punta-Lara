PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hospital_punta_lara
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=
# En Railway tambien se puede usar MYSQL_URL o MYSQLHOST/MYSQLPORT/MYSQLUSER/MYSQLPASSWORD/MYSQLDATABASE.

JWT_SECRET=cambiar_este_valor
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambiar_este_valor_refresh
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

FRONTEND_URL=https://hopital-punta-lara.vercel.app
CORS_ORIGINS=https://hopital-punta-lara.vercel.app,http://localhost:5173,http://localhost:4173,capacitor://localhost

MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# Produccion recomendada: envio por API HTTPS en lugar de SMTP.
# Si RESEND_API_KEY existe, el sistema usa Resend y no usa SMTP.
RESEND_API_KEY=
RESEND_FROM=

# En Railway: queue. En desarrollo tradicional: direct.
WHATSAPP_DELIVERY_MODE=direct
# Misma clave aleatoria de 32+ caracteres en Railway y en la PC agente.
WHATSAPP_AGENT_KEY=
# Solo en la PC agente (URL publica HTTPS del backend Railway).
WHATSAPP_AGENT_API_URL=
WHATSAPP_AGENT_ID=
WHATSAPP_AGENT_POLL_MS=5000
WHATSAPP_QUEUE_MAX_ATTEMPTS=5
WHATSAPP_QUEUE_RETRY_SECONDS=30
WHATSAPP_QUEUE_LOCK_MINUTES=5
WHATSAPP_SESSION_PATH=
WHATSAPP_CHROME_PATH=
WHATSAPP_HEADLESS=true
WHATSAPP_ENABLE_INCOMING_BOT=false
