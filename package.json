{
  "name": "hospital-punta-lara",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "db:sync:prod": "node scripts/sync-prod-db-to-local.js",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "start:backend": "npm --prefix backend run start",
    "whatsapp:agent": "npm --prefix backend run whatsapp:agent",
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "backup:production": "node scripts/backup-production-db.js",
    "android:sync": "npm --prefix frontend run android:sync",
    "android:open": "npm --prefix frontend run android:open",
    "android:apk": "npm --prefix frontend run android:apk"
  }
}
